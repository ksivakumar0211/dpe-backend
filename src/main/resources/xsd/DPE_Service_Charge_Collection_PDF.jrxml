    <parameter name="fromDate" class="java.lang.String"/>
    <parameter name="toDate" class="java.lang.String"/>
    <parameter name="paymentThrough" class="java.lang.String"/>
    <queryString>
        <![CDATA[select cc.chit_no,cc.cfs_no,cc.cfs_date,cc.service_type_cd,
cc.amount,cc.cgst,cc.sgst,cc.total_val,cc.payment_no,cc.payment_date,
cc.ref_tran_no,cc.p2prequestid,cc.status,cc.ref_assess_tds,
cc.service_name,cc.payment_through,cc.bank_receipt_no,cc.transaction_dt,
cc.container_no,cc.party_cd,cc.agent_customer_name
from dpe_service_chg_collection_vw cc
where cc.msg_file_name is not null
and (cc.transaction_dt between
to_date($P{fromDate},'dd/mm/yyyy hh24:mi:ss') and to_date($P{toDate},'dd/mm/yyyy hh24:mi:ss'))
and (cc.payment_through = $P{paymentThrough} or $P{paymentThrough} = 'ALL')]]>
    </queryString>
